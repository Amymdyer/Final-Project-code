#Now I will stack 10 of them (the same temp)
#to get the mean and standard devaition of the bias frames
import glob #this is used to find all the bias frames with the same temp
from astropy.stats import sigma_clip #helps with sigma clipping
allfiles = sorted(glob.glob('bias_-18.2C_*.fits')) #sorted puts them in order
biasframes1 = [] 
for a in allfiles: 
    with fits.open(a) as hdu:
        biasframes1.append(hdu[0].data) 

biasframes1 = np.array(biasframes1, dtype=np.float64) #gives biasframes1 the data
print(biasframes1.shape, 'this is bias shape')
meanforalldata = np.mean(biasframes1, axis=(1,2)) #this is xbar in sigma clipping
stdsforalldata = np.std(biasframes1, axis=(1,2)) # this is sigma for sigma clipping

averagepixvalue = np.mean(meanforalldata)
print('mean bias level for -18.2', np.mean(meanforalldata))
print('standard deviation for -18.2', np.std(meanforalldata))


print("Std of first bias frame:", np.std(biasframes1[0]))
print("Mean image std:", np.mean(np.std(biasframes1, axis=(1,2))))
stdimage1 = np.mean(np.std(biasframes1, axis=(1,2)))
#sigma clipping test for -18.2C

x_bar = np.mean(meanforalldata)

clipped = np.abs(meanforalldata - x_bar) <= 3 * stdsforalldata #any value above sigma*3 will be clipped

clippedmeans = meanforalldata[clipped] #clipping the means for any issues

#finding readout noise: 

stdofimages = np.std(biasframes1, axis=0, ddof=1) #reading from each pixel 

print("Std image shape:", stdofimages.shape) #shape should be x and y of image

plt.imshow(stdofimages, origin='lower', cmap='gray') #shows the image
plt.colorbar(label='(ADU)')
plt.xlabel('x pixel value')
plt.ylabel('y pixel value')
plt.title('Masterbias std (-18.2C)')
plt.show()

readoutnoise = np.mean(stdofimages) #calculating readout noise

print("Read-out noise (ADU):", readoutnoise) #pixel noise in adu but to change to electrons, need gain. 

#making bias master frame: 
clipbiases = sigma_clip(biasframes1, sigma=3, axis=0)
masterbias = np.mean(clipbiases, axis=0)

print("Master bias mean (ADU):", np.mean(masterbias)) 
print("Master bias std (ADU):", np.std(masterbias, ddof=1))

hdu = fits.PrimaryHDU(masterbias) #creates file for masterbias
hdu.header['COMMENT'] = 'Master bias frame (-18 C)' #titles it
hdu.writeto('master_bias_-18.2C.fits', overwrite=True) #if rerun doesnt create new file just overwrites it 

plt.imshow(masterbias, origin='lower', cmap='grey', vmax=241, vmin=238) #displaying image, origins lower means zeros will match
plt.colorbar(label='(ADU)') 
plt.xlabel('x pixel value')
plt.ylabel('y pixel value')
plt.title('Master Bias Frame: -18C degrees') #the bias frame, hoping to not see anything.
plt.show()
