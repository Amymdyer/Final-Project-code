#FLAT FRAME CALIBRATION
from numpy.polynomial.legendre import Legendre

flatimages = sorted(glob.glob("LED_flat_2s_*.fits")) #stacking the flats
flats = [] #array for the flat

for file in flatimages:
    data = fits.getdata(file) #getting data 
    calibrated = data - masterbias - masterdark #subtracting the masterbias and dark
    flats.append(calibrated)

flats = np.array(flats) #creating an array of the flat stack
masterflat = np.median(flats, axis=0) #creating a master flat
flatmed = np.median(masterflat, axis=0) #median of the flat

x = np.arange(len(flatmed)) #range of the values of the median flat

poly = Legendre.fit(x, flatmed, deg=5) #Legrande polynomial fit
fit = poly(x) #scaled polynomial fit
flatnorm = flatmed / fit #median of falt over the polynomal fit to create normalization

median = np.median(flatnorm) #median of the flat normalization
std = np.std(flatnorm) #standard deviation of the flat normalization 

print("Median:", median)
print("Standard Deviation:", std)

hdu = fits.PrimaryHDU(masterflat) #creates file for masterbias
hdu.header['COMMENT'] = 'Master flat frame (-18 C)' #titles it
hdu.writeto('master_flat.fits', overwrite=True) #if rerun doesnt create new file just overwrites it 


# plot
plt.figure()
plt.plot(flatmed, 'o', markersize=1, label="Flat") #plot of the polynomial against the data
plt.plot(fit, label="Legendre Fit")
plt.xlabel('Pixel Value')
plt.ylabel('Counts')
plt.title('Legrande Fit vs The Data')
plt.legend()
plt.show()

