#NEW MASTER BIAS AT NEW TEMPERATURE -17C
import glob #this is used to find all the bias frames with the same temp 

allfiles = sorted(glob.glob('bias_-17C_*.fits')) #sorted puts them in order
biasframes1 = [] 
for a in allfiles: 
    with fits.open(a) as hdu:
        biasframes1.append(hdu[0].data) 

biasframes1 = np.array(biasframes1) #gives biasframes1 the data
print(biasframes1.shape, 'this is bias shape')
meanforalldata = np.mean(biasframes1, axis=(1,2)) #this is xbar in sigma clipping
stdsforalldata = np.std(biasframes1, axis=(1,2)) # this is sigma for sigma clipping
#sigma clipping test for -17.C


clipped = sigma_clip(meanforalldata, sigma=3, axis=0)
clippedmeans = clipped.compressed()  #would remove any image where its mean isnt below 3std

print('sigma clipping bias mean:', clippedmeans)
print("Rejected frame means:", meanforalldata[clipped.mask])  #seeing if any frame is rejected
    

#making bias master frame: 
clipbiases = sigma_clip(biasframes1, sigma=3, axis=0)
masterbias = np.mean(clipbiases, axis=0)

print("Master bias mean (ADU):", np.mean(masterbias)) 
print("Master bias std (ADU):", np.std(masterbias, ddof=1))

hdu = fits.PrimaryHDU(masterbias) #creates file for masterbias
hdu.header['COMMENT'] = 'Master bias frame (-17 C)' #titles it
hdu.writeto('master_bias_-17C.fits', overwrite=True) #if rerun doesnt create new file just overwrites it 

plt.imshow(masterbias, origin='lower', cmap='grey') #displaying image, origins lower means zeros will match
plt.colorbar() 
plt.title('Master Bias Frame: -17 degrees') #the bias frame, hoping to not see anything.
plt.show()
