import glob

darks17_30 = sorted(glob.glob('dark_-17C_30s_*fits')) #stacking the 5 dark images at this temp

darkstack = []
for f in darks17_30:   
    with fits.open(f) as hdul:
        darks17_30 = hdul[0].data.astype(np.float64) #changing to 64bit
    darkstack.append(darks17_30 - masterbias)

