print('Dark current (17C30s):', darkcurrent1730s)
threshold = medianofflat + 10 * medabs #creates a threshold of any pixels abobe 10x the medium
hotpixel = masterdark > threshold # hotpixels above threshold in just the mean

numhotpixels = np.sum(hotpixel)
